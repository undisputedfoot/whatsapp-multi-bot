# ============================================
#  WhatsApp Multi-Bot — Configuration Template
#  Copy to .env and fill in your values
# ============================================

# ----- Language (en, es, hi, ar, fr, pt, de, ja) -----
BOT_LANGUAGE=en

# ----- Multi-Session -----
SESSION_NAMES=main

# ----- Browser -----
BROWSER_MODE=local
CHROME_WS=

# ----- Features -----
AUTO_REPLY_ON=true
AUTO_STATUS_VIEW=true
READ_RECEIPTS=false
AUTO_REJECT_CALLS=true
STICKER_MAKER=true
CALL_REJECT_MSG=I'm unavailable. Please text me.

# ----- AI Replies -----
# Providers: openai, groq, openrouter, gemini, none
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Reply concisely and naturally.

# ----- Gemini (used when AI_PROVIDER=gemini) -----
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ----- Groq (separate key, used when AI_PROVIDER=groq) -----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ----- ChatGPT Personas -----
PERSONA_DEFAULT=You are a helpful WhatsApp assistant. Reply concisely and naturally.

# ----- Human-like Typing -----
HUMAN_TYPING=true
TYPING_MIN_DELAY=3
TYPING_MAX_DELAY=7

# ----- Business Hours -----
BIZ_HOURS_ENABLED=false
BIZ_HOURS_START=09:00
BIZ_HOURS_END=18:00
BIZ_HOURS_WEEKDAYS=1,2,3,4,5
BIZ_CLOSED_MSG=We're currently closed. Hours: {start}-{end} weekdays.

# ----- Media Gallery -----
MEDIA_AUTO_DOWNLOAD=true

# ----- Plugin System -----
PLUGINS_ENABLED=true

# ----- Auto-Update -----
AUTO_UPDATE=false
UPDATE_BRANCH=main

# ----- Admin System -----
ADMIN_NUMBERS=

# ----- Group Management -----
GROUP_WELCOME_ON=true
GROUP_ANTI_LINK=false
GROUP_ANTI_LINK_ACTION=warn
GROUP_AUTO_REPLY_IN_GROUPS=false

# ----- Broadcast -----
BROADCAST_INTERVAL_SEC=5

# ----- Web Dashboard -----
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
DASHBOARD_USER=admin
DASHBOARD_PASS=admin123

# ----- Webhook -----
WEBHOOK_URL=
WEBHOOK_SECRET=
